# Base URL for the backend API. The app calls `${VITE_API_BASE_URL}/factories`, etc.
# Leave as "/api" to use the Vite dev proxy (see VITE_API_PROXY below).
VITE_API_BASE_URL=/api

# When using "/api" above, set this to your backend origin so Vite proxies requests.
# Example for a local Laravel app:
VITE_API_PROXY=http://localhost:8000
